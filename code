#include <iostream>
#include <vector>
using namespace std;

struct Book {
    int id;
    string title, author;
    bool issued = false;
};

int main() {
    vector<Book> books;
    int choice, id;
    string title, author;

    do {
        cout << "\n1.Add Book  2.Issue Book  3.Return Book  4.Search  5.Exit\n";
        cin >> choice;

        switch (choice) {
        case 1:
            cout << "ID Title Author: ";
            cin >> id >> title >> author;
            books.push_back({id, title, author, false});
            break;

        case 2:
            cout << "Book ID: ";
            cin >> id;
            for (auto &b : books)
                if (b.id == id) b.issued = true;
            break;

        case 3:
            cout << "Book ID: ";
            cin >> id;
            for (auto &b : books)
                if (b.id == id) b.issued = false;
            break;

        case 4:
            cout << "Enter Title: ";
            cin >> title;
            for (auto b : books)
                if (b.title == title)
                    cout << b.id << " " << b.title << " " << b.author << endl;
            break;
        }
    } while (choice != 5);

    return 0;
}
